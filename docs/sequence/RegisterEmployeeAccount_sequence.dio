    <diagram id="e09OxtVZlyJV_OfbN8VU" name="ページ1">
        <mxGraphModel dx="2119" dy="3036" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;sequenceDiagram\n    actor 管理者\n    participant BP003 as BP003&lt;br/&gt;担当者アカウント登録画面\n    participant BP004 as BP004&lt;br/&gt;担当者アカウント登録確認画面\n    participant BP005 as BP005&lt;br/&gt;担当者アカウント登録完了画面\n    participant Service as EmployeeAccountService\n    participant Repository as EmployeeAccountRepository\n    participant API as 管理者API\n    participant DB as データベース\n\n    管理者-&gt;&gt;BP003: BP003を開く\n    BP003-&gt;&gt;Service: 未登録社員一覧取得()\n    Service-&gt;&gt;Repository: getUnregisteredEmployees()\n    Repository-&gt;&gt;API: GET /api/admin/employees/unregistered\n    API-&gt;&gt;DB: 未登録社員一覧取得\n    DB--&gt;&gt;API: 未登録社員一覧\n    API--&gt;&gt;Repository: 200 OK\n    Repository--&gt;&gt;Service: 未登録社員一覧\n    Service--&gt;&gt;BP003: 未登録社員一覧\n    BP003--&gt;&gt;管理者: プルダウン表示\n\n    alt 社員データ取得エラー\n        Service--&gt;&gt;BP003: エラー\n        BP003--&gt;&gt;管理者: 「社員情報の取得に失敗しました」\n    else 未登録社員なし\n        Service--&gt;&gt;BP003: 空データ\n        BP003--&gt;&gt;管理者: 「登録可能な社員が存在しません」\n    end\n\n    管理者-&gt;&gt;BP003: 社員・アカウント名・パスワード入力\n    管理者-&gt;&gt;BP003: 「確認」ボタン押下\n\n    BP003-&gt;&gt;Service: 入力値チェック()\n    Service--&gt;&gt;BP003: チェック結果\n\n    alt 入力値エラー\n        BP003--&gt;&gt;管理者: エラー表示\n    else OK\n        BP003-&gt;&gt;BP004: 確認画面へ遷移\n    end\n\n    管理者-&gt;&gt;BP004: 「登録」ボタン押下\n\n    BP004-&gt;&gt;Service: registerEmployeeAccount()\n    Service-&gt;&gt;Repository: registerEmployeeAccount()\n    Repository-&gt;&gt;API: POST /api/admin/accounts\n\n    API-&gt;&gt;DB: 社員存在確認\n    DB--&gt;&gt;API: 結果\n\n    API-&gt;&gt;DB: アカウント名重複確認\n    DB--&gt;&gt;API: 結果\n\n    alt アカウント名重複\n        API--&gt;&gt;Repository: 409 Conflict\n        Repository--&gt;&gt;Service: 重複エラー\n        Service--&gt;&gt;BP004: エラー\n        BP004--&gt;&gt;管理者: 「このアカウント名は既に使用されています」\n    else 登録成功\n        API-&gt;&gt;DB: アカウント登録\n        DB--&gt;&gt;API: 登録完了\n        API--&gt;&gt;Repository: 201 Created\n        Repository--&gt;&gt;Service: 登録成功\n        Service--&gt;&gt;BP005: 登録完了画面表示\n        BP005--&gt;&gt;管理者: 登録完了メッセージ表示\n    else DB登録エラー\n        API--&gt;&gt;Repository: 500 Error\n        Repository--&gt;&gt;Service: エラー\n        Service--&gt;&gt;BP004: エラー\n        BP004--&gt;&gt;管理者: 「登録処理に失敗しました」\n    end\n\n    alt セッションデータ不足\n        BP004--&gt;&gt;BP003: 登録画面へリダイレクト\n    else セッションタイムアウト\n        BP004--&gt;&gt;BP003: 登録画面へリダイレクト\n    end&quot;&#xa;}" id="2">
                    <mxCell style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;image=data:image/svg+xml,;" vertex="1" parent="1">
